{
    "name": "se7enxweb/metadata-bundle",
    "description": "Metadata bundle for Ibexa 5.x / Exponential Platform. Based on xrowmetadata extension for eZ Publish Legacy.",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Netgen",
            "homepage": "https://netgen.io"
        },
        {
            "name": "xrow GmbH",
            "homepage": "http://www.xrow.de"
        }
    ],
    "require": {
        "php": "^8.4",
        "ibexa/core": "^5.0"
    },
    "replace": {
        "netgen/metadata-bundle": "self.version"
    },
    "autoload": {
        "psr-4": { "Netgen\\Bundle\\MetadataBundle\\": "bundle/" }
    },
    "extra": {
        "branch-alias": {
            "dev-5.0.x": "5.0.x-dev"
        }
    }
}
